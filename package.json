{
    "name": "ticket-generator",
    "version": "1.0.0",
    "private": true,
    "repository": "https://github.com/felixhir/ticket-generator",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build --turbopack",
        "deploy": "next build && cd . > dist/.nojekyll && gh-pages -d dist --dotfiles",
        "start": "next start",
        "docker:build": "docker build -t ticket-generator:local .",
        "docker:run": "docker run --rm -p 3000:3000 ticket-generator:local",
        "check": "biome check .",
        "lint": "biome check .",
        "format": "biome check --write .",
        "prepare": "husky"
    },
    "dependencies": {
        "@bwip-js/browser": "4.10.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "html-to-image": "1.11.13",
        "i18next": "^26.0.8",
        "i18next-browser-languagedetector": "^8.2.1",
        "jspdf": "^4.2.1",
        "jszip": "^3.10.1",
        "lucide-react": "^1.11.0",
        "moment": "2.30.1",
        "next": "16.2.4",
        "radix-ui": "^1.4.3",
        "react": "19.2.5",
        "react-barcode": "1.6.1",
        "react-colorful": "5.6.1",
        "react-datepicker": "9.1.0",
        "react-dom": "19.2.5",
        "react-i18next": "^17.0.4",
        "rgb-hex": "4.1.0",
        "shadcn": "^4.4.0",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.13",
        "@tailwindcss/postcss": "4.2.4",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "gh-pages": "6.3.0",
        "husky": "9.1.7",
        "tailwindcss": "4.2.4",
        "typescript": "6.0.3"
    }
}
